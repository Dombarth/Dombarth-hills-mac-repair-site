<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <link rel="stylesheet" href="/assets/css/style.css">
  <title>{{ title or 'Hills District Mac Repair' }}</title>
</head>
<body>
<header class="top">
  <div class="wrap">
    <a href="/" class="logo-link">
      <svg class="logo-svg" viewBox="0 0 280 50" xmlns="http://www.w3.org/2000/svg">
        <!-- Mac laptop icon -->
        <rect x="4" y="6" width="34" height="24" rx="3" fill="#fff" stroke="#e2e8f0" stroke-width="1"/>
        <rect x="7" y="9" width="28" height="18" rx="1" fill="#1a365d"/>
        <!-- Apple-style apple on screen -->
        <path d="M21,14 C21,12 23,11 24,11 C24,12 23,13 23,14 C23,15 24,16 24,17 C24,19 22,20 21,20 C20,20 18,19 18,17 C18,16 19,15 19,14 C19,13 18,12 18,11 C19,11 21,12 21,14 Z" fill="#fff"/>
        <path d="M22,10 C22.5,9.5 23.5,9 24,9.5 C24,10 23,10.5 22,10 Z" fill="#fff"/>
        <!-- Laptop base -->
        <polygon points="2,32 40,32 38,36 4,36" fill="#fff" stroke="#e2e8f0" stroke-width="1"/>
        <!-- Orange gear/wrench accent -->
        <circle cx="34" cy="28" r="8" fill="#FF7A00"/>
        <path d="M31,26 L34,23 L37,26 L34,29 Z" fill="#fff"/>
        <circle cx="34" cy="28" r="2" fill="#FF7A00"/>
        <!-- Text -->
        <text x="48" y="20" font-family="system-ui, -apple-system, sans-serif" font-size="17" font-weight="800" fill="#fff">Hills Mac Repair</text>
        <text x="48" y="36" font-family="system-ui, -apple-system, sans-serif" font-size="11" fill="#e2e8f0">MacBook &amp; iMac Specialists</text>
      </svg>
    </a>
    <a class="call" href="tel:0400454859">
      <span class="call-icon">📞</span>
      <span class="call-text">0400 454 859</span>
    </a>
  </div>
</header>
<nav class="nav">
  <div class="wrap nav-inner">
    <a href="/">Home</a>
    <a href="/suburbs/">Suburbs</a>
    <a href="/pages/booking.html">Booking</a>
    <a href="/pages/terms-warranty.html">Terms & Warranty</a>
    <a href="/pages/contact.html">Contact</a>
  </div>
</nav>

{% if hero %}
<section class="hero" style="background-image:url('/assets/img/hero.jpg')">
  <div class="wrap">
    <h1>{{ title }}</h1>
    <p class="sub">Fast, professional repairs for MacBook Air/Pro, iMac, and more.</p>
    <p><a class="btn" href="/pages/booking.html">Book a Repair</a> <a class="btn ghost" href="tel:0400454859">Call 0400 454 859</a></p>
  </div>
</section>
{% endif %}

<main class="wrap">
{{ content | safe }}
</main>

<footer class="foot">
  <div class="wrap">
    <p>$150 diagnostic — waived with repair • New parts: 12 months • Used/Aftermarket: 30 days</p>
    <small>Independent specialist — not affiliated with Apple Inc.</small>
  </div>
</footer>
</body>
</html>
