{% set svc = services[service] %}
<div class="card service-card-embed" id="{{ service }}">
  <div class="service-header">
    <h3><a href="/services/{{ svc.slug }}/">{{ svc.name }}</a> — From ${{ svc.from }}</h3>
    <a href="/services/{{ svc.slug }}/" class="service-link">Full Details →</a>
  </div>
  <p class="small">Final price depends on model and inspection. Diagnostic fee is <strong>$150</strong>, waived if you proceed with the repair.</p>
  <div class="badges">
    <span class="badge">⏱️ {{ svc.turnaround }}</span>
    <span class="badge">✓ 12‑month warranty</span>
    <span class="badge">📍 Hills District</span>
  </div>
  <div class="grid" style="margin-top:12px">
    <div class="box">
      <h4>Common Symptoms</h4>
      <ul>{% for s in svc.symptoms | slice(0, 4) %}<li>{{ s }}</li>{% endfor %}</ul>
    </div>
    <div class="box">
      <h4>What We Do</h4>
      <ol>{% for w in svc.what %}<li>{{ w }}</li>{% endfor %}</ol>
    </div>
  </div>
  <p class="cta-row">
    <a class="btn" href="/services/{{ svc.slug }}/">Learn More</a>
    <a class="btn" href="/pages/booking.html">Book Repair</a>
    <a class="btn ghost-dark" href="tel:0400454859">Call Us</a>
  </p>
</div>

<style>
.service-card-embed {
  margin-bottom: 1.5rem;
}
.service-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.service-header h3 {
  margin: 0;
}
.service-header h3 a {
  color: inherit;
  text-decoration: none;
}
.service-header h3 a:hover {
  color: #FF7A00;
}
.service-link {
  color: #FF7A00;
  font-weight: 600;
  font-size: 0.9rem;
  text-decoration: none;
}
.service-link:hover {
  text-decoration: underline;
}
.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin: 0.75rem 0;
}
.cta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1rem;
}
.btn.ghost-dark {
  background: transparent;
  border: 2px solid #1a365d;
  color: #1a365d;
}
</style>
