{% set svc = services[service] %}
<div class="card" id="{{ service }}">
  <h3>{{ svc.name }} — From ${{ svc.from }}</h3>
  <p class="small">Final price depends on model and inspection. Diagnostic fee is <strong>$150</strong>, waived if you proceed with the repair.</p>
  <div>
    <span class="badge">Same‑day options</span>
    <span class="badge">12‑month (new parts)</span>
    <span class="badge">30‑day (used/aftermarket)</span>
  </div>
  <div class="grid" style="margin-top:12px">
    <div class="box">
      <h4>Common Symptoms</h4>
      <ul>{% for s in svc.symptoms %}<li>{{ s }}</li>{% endfor %}</ul>
    </div>
    <div class="box">
      <h4>Likely Causes</h4>
      <ul>{% for c in svc.causes %}<li>{{ c }}</li>{% endfor %}</ul>
    </div>
    <div class="box">
      <h4>What We Do</h4>
      <ol>{% for w in svc.what %}<li>{{ w }}</li>{% endfor %}</ol>
      <p><strong>Turnaround:</strong> {{ svc.turnaround }}</p>
    </div>
  </div>
  <p><a class="btn" href="/pages/booking.html">Book a Repair</a> <a class="btn" href="tel:0400454859">Call 0400 454 859</a></p>
</div>